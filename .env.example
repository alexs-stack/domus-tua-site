# ─────────────────────────────────────────────────────────────
# Domus Tua — variabili d'ambiente (TEMPLATE)
#
# Copia questo file in `.env.local` (dev) e valorizzalo con i dati reali.
# `.env.local` NON va committato (già in .gitignore).
# In produzione: imposta le stesse chiavi su Vercel → Settings → Environment Variables.
#
# ⚠️ Nessun valore reale qui dentro: solo placeholder o default sicuri.
#    Le REALSMART_* e i secret sono SERVER-ONLY: mai prefisso NEXT_PUBLIC_.
# Dettagli: docs/env-and-deploy.md, docs/deployment-notes.md, docs/realsmart-integration-notes.md
# ─────────────────────────────────────────────────────────────

# ─── Pubbliche (NEXT_PUBLIC_* → finiscono nel bundle client) ───

NEXT_PUBLIC_SITE_URL=                    # URL canonico del sito (metadataBase, OG/canonical, sitemap/robots). Prod = dominio finale; Preview = URL Vercel
NEXT_PUBLIC_USE_REALSMART=false          # true = usa il feed RealSmart live; false = mock/demo (app/lib/realsmart/mocks.ts)
NEXT_PUBLIC_PREVIEW_BADGE=true           # mostra il badge "anteprima/demo" (true in preview; false in produzione finale)
NEXT_PUBLIC_ENABLE_I18N=false            # OPT-IN: "true" mostra il selettore lingua (it/en/fr/de/es). Default false = solo-italiano (consigliato per la prima presentazione). Vedi docs/client-demo-mode.md

# ─── RealSmart (gestionale = single source of truth immobili) ───
# Tutte le REALSMART_* sono SERVER-ONLY. Finché sono vuote, il sito gira sui mock.

REALSMART_FEED_URL=                      # feed XML immobili. LIVE: default nel codice (env.ts) = https://www.gestim2002.it/portali/immobili_724.xml (URL pubblico, non segreto). Sovrascrivi qui solo se cambia.
REALSMART_API_KEY=                       # chiave/token per autenticare il feed o le API RealSmart
REALSMART_API_BASE=                      # base URL delle API REST RealSmart (scenario API)
REALSMART_FTP_HOST=                      # host FTP/SFTP se il feed è consegnato via file (scenario FTP)
REALSMART_FTP_USER=                      # utente FTP/SFTP
REALSMART_FTP_PASS=                      # password FTP/SFTP (secret)
REALSMART_FTP_PATH=                      # percorso remoto del file feed (es. /export/immobili.xml)
REALSMART_WEBHOOK_SECRET=                # segreto per verificare la firma dei webhook RealSmart (rivalidazione on-demand)

# ─── Contatti / lead ───

CONTACT_FORM_MODE=whatsapp               # destinazione del form contatti: whatsapp | email (vedi docs/forms-crm-notes.md)
CONTACT_EMAIL_TO=                        # indirizzo destinatario lead quando CONTACT_FORM_MODE=email
SHEETS_WEBHOOK_URL=                      # SERVER-ONLY. URL della Google Apps Script Web App che scrive i lead sul Google Sheet. Il form POSTa a /api/lead che inoltra qui. Vuoto = lead non salvati (resta solo WhatsApp). Setup: docs/form-backend-next-step.md

# ─── Ricerca AI immobili (opt-in — vedi docs/ai-search.md) ───

ANTHROPIC_API_KEY=                       # SERVER-ONLY. Chiave Anthropic per il parsing della frase in filtri (Claude Haiku). Vuota = parser locale deterministico (funziona comunque).
AI_SEARCH_MODEL=                         # opzionale, override del modello (default: claude-haiku-4-5-20251001)
VOYAGE_API_KEY=                          # SERVER-ONLY. Chiave Voyage AI per gli embeddings (ranking semantico). Vuota = ranking per parole chiave.
VOYAGE_MODEL=                            # opzionale, override del modello embeddings (default: voyage-3.5-lite)
NEXT_PUBLIC_ENABLE_ASSISTANT=            # "true" per mostrare l'assistente conversazionale (chat). Richiede anche ANTHROPIC_API_KEY. Vuoto/false = nascosto.
AI_ASSISTANT_MODEL=                      # opzionale, override del modello dell'assistente (default: claude-haiku-4-5-20251001)

# ─── Embed di terze parti (recensioni / social) ───

TRUSTINDEX_WIDGET_URL=                   # URL/script del widget recensioni Trustindex (docs/reviews-integration.md)
INSTAGRAM_WIDGET_URL=                    # URL/embed del feed Instagram
